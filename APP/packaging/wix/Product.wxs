<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">

  <Product
    Id="*"
    Name="MyEnterpriseXMLApp"
    Language="1036"
    Version="2.0.0"
    Manufacturer="Luz Informatique"
    UpgradeCode="{F1B7C9C3-0F6D-4E52-9B9F-5E4A1F9C8C11}">

    <Package
      InstallerVersion="500"
      Compressed="yes"
      InstallScope="perMachine" />

    <!-- Permet la mise à jour automatique du MSI -->
    <MajorUpgrade
      DowngradeErrorMessage="Une version plus récente de MyEnterpriseXMLApp est déjà installée." />

    <MediaTemplate />

    <!-- Arborescence d'installation -->
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFilesFolder">
        <Directory Id="INSTALLFOLDER" Name="MyEnterpriseXMLApp"/>
      </Directory>
    </Directory>

    <!-- Fichiers installés -->
    <DirectoryRef Id="INSTALLFOLDER">
      <Component
        Id="MainExecutable"
        Guid="{9A5E6E2C-6F1E-4C6A-A1C9-2C3A6E5E3F77}">

        <File
          Id="MyEnterpriseXMLAppExe"
          Source="$(var.ProjectDir)dist\MyEnterpriseXMLApp\MyEnterpriseXMLApp.exe"
          KeyPath="yes" />

      </Component>
    </DirectoryRef>

    <!-- Fonctionnalité principale -->
    <Feature
      Id="MainFeature"
      Title="MyEnterpriseXMLApp"
      Level="1">

      <ComponentRef Id="MainExecutable"/>

    </Feature>

  </Product>

</Wix>
