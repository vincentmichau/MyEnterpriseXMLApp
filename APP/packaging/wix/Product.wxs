
<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product
    Id="*"
    Name="!(loc.ProductName)"
    Language="!(loc.Culture)"
    Version="2.1.0"
    Manufacturer="Luz Informatique"
    UpgradeCode="{F1B7C9C3-0F6D-4E52-9B9F-5E4A1F9C8C11}">

    <Package InstallerVersion="500" Compressed="yes" InstallScope="perMachine" />

    <MajorUpgrade Schedule="afterInstallInitialize" DowngradeErrorMessage="A newer version is already installed." />

    <MediaTemplate />

    <!-- Branding -->
    <Icon Id="IconInstalled" SourceFile="$(var.ProjectDir)APP\assets\MyEnterpriseXMLApp_installed.ico" />
    <Property Id="ARPPRODUCTICON" Value="IconInstalled" />

    <WixVariable Id="WixUILicenseRtf" Value="$(var.ProjectDir)APP\assets\license.rtf" />
    <WixVariable Id="WixUIBannerBmp" Value="$(var.ProjectDir)APP\assets\banner.bmp" />
    <WixVariable Id="WixUIDialogBmp" Value="$(var.ProjectDir)APP\assets\dialog.bmp" />

    <Property Id="ARPNOMODIFY" Value="1" />
    <Property Id="ARPNOREPAIR" Value="1" />

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFilesFolder">
        <Directory Id="INSTALLFOLDER" Name="MyEnterpriseXMLApp" />
      </Directory>
      <Directory Id="ProgramMenuFolder">
        <Directory Id="ProgramMenuDir" Name="MyEnterpriseXMLApp" />
      </Directory>
      <Directory Id="DesktopFolder" />
    </Directory>

    <DirectoryRef Id="INSTALLFOLDER">
      <Component Id="MainExe" Guid="{9A5E6E2C-6F1E-4C6A-A1C9-2C3A6E5E3F77}">
        <File Id="AppExe" Source="$(var.ProjectDir)dist\MyEnterpriseXMLApp\MyEnterpriseXMLApp.exe" KeyPath="yes">
          <Shortcut Id="DesktopShortcut" Directory="DesktopFolder" Name="MyEnterpriseXMLApp" Advertise="no" />
          <Shortcut Id="StartMenuShortcut" Directory="ProgramMenuDir" Name="MyEnterpriseXMLApp" Advertise="no" />
        </File>
        <RemoveFolder Id="RemoveMenu" Directory="ProgramMenuDir" On="uninstall" />
      </Component>
    </DirectoryRef>

    <!-- File associations -->
    <DirectoryRef Id="TARGETDIR">
      <Component Id="FileAssoc" Guid="{6F2A2E5C-0D0B-4C3C-AF3A-55F0D2A50173}">
        <ProgId Id="MyEnterpriseXMLApp.xml" Description="XML Document">
          <Extension Id="xml" />
          <Extension Id="xsd" />
          <Extension Id="xslt" />
        </ProgId>
        <RegistryValue Root="HKCR" Key="MyEnterpriseXMLApp.xml\shell\open\command"
          Value="&quot;[INSTALLFOLDER]MyEnterpriseXMLApp.exe&quot; &quot;%1&quot;"
          Type="string" KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <Feature Id="MainFeature" Title="!(loc.FeatureMain)" Level="1">
      <ComponentRef Id="MainExe" />
      <ComponentRef Id="FileAssoc" />
    </Feature>

    <UIRef Id="WixUI_Mondo" />
    <UIRef Id="WixUI_ErrorProgressText" />

  </Product>
</Wix>
